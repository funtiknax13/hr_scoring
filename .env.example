# Скопируй в .env и впиши свой токен DeepSeek
DEEPSEEK_API_KEY=sk-...
# По умолчанию https://api.deepseek.com — менять не нужно
DEEPSEEK_BASE_URL=https://api.deepseek.com

# SuperJob API — ключ из личного кабинета api.superjob.ru
SJ_API_KEY=v3.r.1...

# HH API — OAuth (обязателен, публичный доступ без токена заблокирован)
# Зарегистрируй приложение на https://dev.hh.ru/, redirect_uri = http://localhost:8765
HH_CLIENT_ID=
HH_CLIENT_SECRET=
# Токен заполняется автоматически после: python hh_fetch.py --auth
HH_TOKEN=
# User-Agent: AppName/Version (your@email.com)
HH_USER_AGENT=HR-Scoring-Tool/1.0 (your@email.com)
